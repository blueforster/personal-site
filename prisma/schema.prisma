generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum PostStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
  ARCHIVED
}

model Post {
  id               String     @id @default(cuid())
  slug             String     @unique
  title            String
  status           PostStatus @default(DRAFT)
  scheduledAt      DateTime?
  publishedAt      DateTime?
  publishPlatforms String     @db.Text
  viewCount        Int        @default(0)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  comments         Comment[]
  likes            Like[]

  @@index([status])
  @@index([slug])
}

model Comment {
  id          String   @id @default(cuid())
  postSlug    String
  authorName  String
  authorEmail String?
  content     String   @db.Text
  approved    Boolean  @default(false)
  ipHash      String
  createdAt   DateTime @default(now())
  post        Post     @relation(fields: [postSlug], references: [slug])

  @@index([postSlug])
}

model Like {
  id        String   @id @default(cuid())
  postSlug  String
  ipHash    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postSlug], references: [slug])

  @@unique([postSlug, ipHash])
  @@index([postSlug])
}

model ScheduledJob {
  id          String    @id @default(cuid())
  postSlug    String
  platforms   String    @db.Text
  scheduledAt DateTime
  executed    Boolean   @default(false)
  executedAt  DateTime?
  error       String?   @db.Text

  @@index([executed, scheduledAt])
}

enum UserRole {
  USER
  ADMIN
}

enum PurchaseStatus {
  COMPLETED
  REFUNDED
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  image     String?
  role      UserRole   @default(USER)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  purchases Purchase[]

  @@index([email])
}

model Purchase {
  id                    String         @id @default(cuid())
  userId                String
  courseSlug             String
  stripeSessionId       String         @unique
  stripePaymentIntentId String?
  amountPaid            Int
  currency              String         @default("twd")
  status                PurchaseStatus @default(COMPLETED)
  createdAt             DateTime       @default(now())
  user                  User           @relation(fields: [userId], references: [id])

  @@unique([userId, courseSlug])
  @@index([userId])
  @@index([courseSlug])
}
